---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import MermaidScript from '../components/MermaidScript.astro';
import ProjectTreeNav from '../components/ProjectTreeNav';
import { getProjectNavData } from '../lib/getProjectNavData';

type DevlogData = CollectionEntry<'devlogs'>['data'];
type ProjectEntry = CollectionEntry<'projects'>;

interface Props extends DevlogData {
	devlogId: string;
	projectEntry: ProjectEntry;
	prevDevlog?: { id: string; project: string; slug: string; seq: number; title: string } | null;
	nextDevlog?: { id: string; project: string; slug: string; seq: number; title: string } | null;
	isPrivate?: boolean;
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	seq,
	type,
	commits,
	tags,
	devlogId,
	projectEntry,
	prevDevlog,
	nextDevlog,
	isPrivate = false,
} = Astro.props;

const navData = await getProjectNavData();

const projectLink = projectEntry.data.draft
	? `/private/projects/${projectEntry.id}/`
	: `/projects/${projectEntry.id}/`;

const linkPrefix = isPrivate ? '/private' : '';

const TYPE_COLOR: Record<string, string> = {
	feat: 'text-[var(--color-accent)] border-[var(--color-accent)]/40 bg-[var(--color-accent-glow)]',
	fix: 'text-blue-300 border-blue-400/40 bg-blue-500/10',
	refactor: 'text-purple-300 border-purple-400/40 bg-purple-500/10',
	docs: 'text-zinc-300 border-zinc-500/40 bg-zinc-500/10',
	ci: 'text-orange-300 border-orange-400/40 bg-orange-500/10',
	security: 'text-red-300 border-red-400/40 bg-red-500/10',
	release: 'text-emerald-300 border-emerald-400/40 bg-emerald-500/10',
	planning: 'text-cyan-300 border-cyan-400/40 bg-cyan-500/10',
	test: 'text-yellow-300 border-yellow-400/40 bg-yellow-500/10',
};
const typeClass = type ? TYPE_COLOR[type] || '' : '';

const repoUrl = projectEntry.data.repoUrl;
const seqStr = String(seq).padStart(3, '0');
---

<html lang="ko">
	<head>
		<BaseHead title={isPrivate ? `[DRAFT] ${title}` : title} description={description} />
		{isPrivate && <meta name="robots" content="noindex,nofollow" />}
	</head>
	<body>
		<Header />
		<main class="wide-page mx-auto max-w-[1400px] px-6 py-12">
			{isPrivate && (
				<div class="mb-6 px-4 py-3 rounded-lg border border-[var(--color-accent)]/40 bg-[var(--color-accent-glow)] font-mono text-xs flex items-center justify-between gap-3 flex-wrap">
					<div class="flex items-center gap-2 text-[var(--color-accent)]">
						<span>📝</span>
						<span class="font-semibold">DRAFT — only you can see this</span>
					</div>
					<a
						href="/private/"
						class="text-[var(--color-fg-dim)] hover:text-[var(--color-accent)] transition"
					>
						← back to private
					</a>
				</div>
			)}

			<div class="grid grid-cols-1 lg:grid-cols-[220px_minmax(0,1fr)] gap-10">
				<ProjectTreeNav
					projects={navData.projects}
					devlogs={navData.devlogs}
					currentDevlogId={devlogId}
					client:load
				/>

				<article class="min-w-0 lg:max-w-3xl">
					<!-- Compact breadcrumb -->
					<div class="flex flex-wrap items-center gap-2 font-mono text-[11px] text-[var(--color-muted)] mb-4">
						<a href={isPrivate ? '/private' : '/projects'} class="hover:text-[var(--color-accent)]">
							{isPrivate ? '../private' : '../projects'}
						</a>
						<span>/</span>
						<a href={projectLink} class="hover:text-[var(--color-accent)]">{projectEntry.data.title}</a>
						<span>/</span>
						<span class="text-[var(--color-fg-dim)]">{seqStr}</span>
					</div>

					<!-- Title block: H1 first, then unified one-line meta -->
					<header class="mb-8 pb-6 border-b border-[var(--color-border)]">
						<h1 class="mb-3 leading-tight">{title}</h1>
						<p class="text-base text-[var(--color-fg-dim)] leading-relaxed mb-4">{description}</p>

						<!-- Single meta line: seq · type · date · tags -->
						<div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[11px] text-[var(--color-muted)]">
							<span class="text-[var(--color-accent)] tabular-nums">#{seqStr}</span>
							{type && (
								<>
									<span class="text-[var(--color-border-strong)]">·</span>
									<span class={`uppercase tracking-wider ${typeClass.split(' ')[0]}`}>{type}</span>
								</>
							)}
							<span class="text-[var(--color-border-strong)]">·</span>
							<time><FormattedDate date={pubDate} /></time>
							{updatedDate && (
								<>
									<span class="text-[var(--color-border-strong)]">·</span>
									<span class="italic">updated <FormattedDate date={updatedDate} /></span>
								</>
							)}
							{tags && tags.length > 0 && (
								<>
									<span class="text-[var(--color-border-strong)]">·</span>
									{tags.map((tag) => (
										<span>#{tag}</span>
									))}
								</>
							)}
						</div>
					</header>

					{heroImage && (
						<div class="mb-10">
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt=""
								class="w-full rounded-lg border border-[var(--color-border)]"
							/>
						</div>
					)}

					<div class="prose">
						<slot />
					</div>

					{commits && commits.length > 0 && (
						<section class="mt-12 pt-6 border-t border-[var(--color-border)]">
							<div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)] mb-3">
								related commits ({commits.length})
							</div>
							<ul class="space-y-1.5 font-mono text-xs">
								{commits.map((sha) => (
									repoUrl ? (
										<li>
											<a
												href={`${repoUrl}/commit/${sha}`}
												target="_blank"
												rel="noopener noreferrer"
												class="inline-flex items-center gap-2 text-[var(--color-fg-dim)] hover:text-[var(--color-accent)] transition"
											>
												<span class="text-[var(--color-accent)]">●</span>
												<span class="tabular-nums">{sha.slice(0, 7)}</span>
												<span class="text-[var(--color-muted)]">↗</span>
											</a>
										</li>
									) : (
										<li class="text-[var(--color-fg-dim)]">
											<span class="text-[var(--color-accent)]">●</span> <span class="tabular-nums">{sha.slice(0, 7)}</span>
										</li>
									)
								))}
							</ul>
						</section>
					)}

					<nav class="mt-12 pt-8 border-t border-[var(--color-border)] grid grid-cols-2 gap-4 font-mono text-sm">
						<div>
							{prevDevlog && (
								<a
									href={`${linkPrefix}/projects/${prevDevlog.project}/${prevDevlog.slug}/`}
									class="group block p-4 border border-[var(--color-border)] rounded hover:border-[var(--color-accent)] transition"
								>
									<div class="text-[10px] text-[var(--color-muted)] uppercase tracking-wider mb-1">← prev</div>
									<div class="text-[var(--color-accent)] tabular-nums">
										#{String(prevDevlog.seq).padStart(3, '0')}
									</div>
									<div class="text-sm text-[var(--color-fg-dim)] group-hover:text-[var(--color-fg)] transition truncate">
										{prevDevlog.title}
									</div>
								</a>
							)}
						</div>
						<div>
							{nextDevlog && (
								<a
									href={`${linkPrefix}/projects/${nextDevlog.project}/${nextDevlog.slug}/`}
									class="group block p-4 border border-[var(--color-border)] rounded hover:border-[var(--color-accent)] transition text-right"
								>
									<div class="text-[10px] text-[var(--color-muted)] uppercase tracking-wider mb-1">next →</div>
									<div class="text-[var(--color-accent)] tabular-nums">
										#{String(nextDevlog.seq).padStart(3, '0')}
									</div>
									<div class="text-sm text-[var(--color-fg-dim)] group-hover:text-[var(--color-fg)] transition truncate">
										{nextDevlog.title}
									</div>
								</a>
							)}
						</div>
					</nav>

					<div class="mt-8">
						<a
							href={projectLink}
							class="inline-flex items-center gap-2 font-mono text-sm text-[var(--color-fg-dim)] hover:text-[var(--color-accent)] transition"
						>
							<span class="text-[var(--color-accent)]">→</span>
							<span>back to project: <span class="underline underline-offset-2">{projectEntry.data.title}</span></span>
						</a>
					</div>

					{!isPrivate && <Comments />}
				</article>
			</div>
		</main>
		<Footer />
		<MermaidScript />
	</body>
</html>
