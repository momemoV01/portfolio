---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import BlogTreeNav from '../components/BlogTreeNav';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import MermaidScript from '../components/MermaidScript.astro';
import { getBlogNavData } from '../lib/getBlogNavData';

type BlogData = CollectionEntry<'blog'>['data'];

interface Props extends BlogData {
	isPrivate?: boolean;
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	tags,
	isPrivate = false,
} = Astro.props;

const navData = await getBlogNavData();

// Current path → derive blog slug for tree highlighting
const currentSlug = Astro.url.pathname.match(/\/blog\/([^/]+)/)?.[1];
---

<html lang="ko">
	<head>
		<BaseHead title={isPrivate ? `[DRAFT] ${title}` : title} description={description} />
		{isPrivate && <meta name="robots" content="noindex,nofollow" />}
	</head>
	<body>
		<Header />
		<main class="wide-page mx-auto max-w-[1400px] px-6 py-12">
			{isPrivate && (
				<div class="mb-6 px-4 py-3 rounded-lg border border-[var(--color-accent)]/40 bg-[var(--color-accent-glow)] font-mono text-xs flex items-center justify-between gap-3 flex-wrap">
					<div class="flex items-center gap-2 text-[var(--color-accent)]">
						<span>📝</span>
						<span class="font-semibold">DRAFT — only you can see this</span>
					</div>
					<a
						href="/private/"
						class="text-[var(--color-fg-dim)] hover:text-[var(--color-accent)] transition"
					>
						← back to private
					</a>
				</div>
			)}

			<div class="grid grid-cols-1 lg:grid-cols-[220px_minmax(0,1fr)] gap-10">
				<BlogTreeNav posts={navData.posts} currentPostId={currentSlug} client:load />

				<article class="min-w-0 lg:max-w-3xl">
					<header class="mb-10">
						<div class="flex items-center gap-3 font-mono text-xs text-[var(--color-muted)] mb-4">
							{category && <span class="text-[var(--color-accent)] uppercase">[{category}]</span>}
							<time>
								<FormattedDate date={pubDate} />
							</time>
							{updatedDate && (
								<span class="italic">· updated <FormattedDate date={updatedDate} /></span>
							)}
						</div>
						<h1 class="mb-4 leading-tight">{title}</h1>
						<p class="text-lg text-[var(--color-fg-dim)] leading-relaxed">{description}</p>
						{tags && tags.length > 0 && (
							<div class="mt-5 flex flex-wrap gap-2 font-mono text-xs">
								{tags.map((tag) => (
									<span class="text-[var(--color-muted)]">#{tag}</span>
								))}
							</div>
						)}
					</header>

					{heroImage && (
						<div class="mb-10">
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt=""
								class="w-full rounded-lg border border-[var(--color-border)]"
							/>
						</div>
					)}

					<div class="prose">
						<slot />
					</div>

					{!isPrivate && <Comments />}
				</article>
			</div>
		</main>
		<Footer />
		<MermaidScript />
	</body>
</html>
