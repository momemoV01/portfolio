---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import MermaidScript from '../components/MermaidScript.astro';
import ProjectTreeNav from '../components/ProjectTreeNav';
import { getProjectNavData } from '../lib/getProjectNavData';

type ProjectData = CollectionEntry<'projects'>['data'];
type DevlogEntry = CollectionEntry<'blog'>;

interface Props extends ProjectData {
	projectId: string;
	devlogs: DevlogEntry[];
	isPrivate?: boolean;
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	coverImage,
	engine,
	platforms,
	tech,
	role,
	duration,
	status,
	playableUrl,
	repoUrl,
	videoUrl,
	projectId,
	isPrivate = false,
} = Astro.props;

const navData = await getProjectNavData();
---

<html lang="ko">
	<head>
		<BaseHead title={isPrivate ? `[DRAFT] ${title}` : title} description={description} />
		{isPrivate && <meta name="robots" content="noindex,nofollow" />}
	</head>
	<body>
		<Header />
		<main class="wide-page mx-auto max-w-[1400px] px-6 py-12">
			{isPrivate && (
				<div class="mb-6 px-4 py-3 rounded-lg border border-[var(--color-accent)]/40 bg-[var(--color-accent-glow)] font-mono text-xs flex items-center justify-between gap-3 flex-wrap">
					<div class="flex items-center gap-2 text-[var(--color-accent)]">
						<span>📝</span>
						<span class="font-semibold">DRAFT — only you can see this</span>
					</div>
					<a
						href="/private/"
						class="text-[var(--color-fg-dim)] hover:text-[var(--color-accent)] transition"
					>
						← back to private
					</a>
				</div>
			)}

			<!-- Breadcrumb (full width) -->
			<div class="flex items-center gap-3 font-mono text-xs text-[var(--color-muted)] mb-6">
				<a href={isPrivate ? '/private' : '/projects'} class="hover:text-[var(--color-accent)]">
					{isPrivate ? '../private' : '../projects'}
				</a>
				<span>/</span>
				<span class="text-[var(--color-fg)]">{title}</span>
			</div>

			<!-- Hero (full width, height capped) -->
			<div class="mb-10 border border-[var(--color-border)] rounded-lg overflow-hidden">
				<Image
					width={1400}
					height={788}
					src={coverImage}
					alt={title}
					class="w-full h-auto max-h-[420px] object-cover aspect-video"
				/>
			</div>

			<!-- Sidebar + content layout -->
			<div class="grid grid-cols-1 lg:grid-cols-[220px_minmax(0,1fr)] gap-10">
				<ProjectTreeNav
					projects={navData.projects}
					devlogs={navData.devlogs}
					currentProjectId={projectId}
					client:load
				/>

				<div class="min-w-0 lg:max-w-4xl">
					<!-- Title block -->
					<header class="mb-10">
						<div class="flex flex-wrap items-center gap-2 mb-4 font-mono text-xs">
							<span class="text-[var(--color-accent)]">[{engine}]</span>
							<span class="text-[var(--color-muted)]">·</span>
							<span class="uppercase tracking-wider text-[var(--color-muted)]">{status}</span>
							<span class="text-[var(--color-muted)]">·</span>
							<time class="text-[var(--color-muted)]"><FormattedDate date={pubDate} /></time>
							{updatedDate && <span class="text-[var(--color-muted)] italic">· updated <FormattedDate date={updatedDate} /></span>}
						</div>
						<h1 class="mb-4 leading-tight">{title}</h1>
						<p class="text-xl text-[var(--color-fg-dim)] leading-relaxed">{description}</p>
					</header>

					<!-- Info grid -->
					<section class="mb-8 border border-[var(--color-border)] rounded-lg">
						<div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-y md:divide-y-0 divide-[var(--color-border)]">
							<div class="p-5">
								<div class="font-mono text-xs text-[var(--color-muted)] uppercase tracking-wider mb-2">Role</div>
								<div class="text-sm">{role}</div>
							</div>
							<div class="p-5">
								<div class="font-mono text-xs text-[var(--color-muted)] uppercase tracking-wider mb-2">Duration</div>
								<div class="text-sm">{duration || '—'}</div>
							</div>
							<div class="p-5">
								<div class="font-mono text-xs text-[var(--color-muted)] uppercase tracking-wider mb-2">Engine</div>
								<div class="text-sm">{engine}</div>
							</div>
							<div class="p-5">
								<div class="font-mono text-xs text-[var(--color-muted)] uppercase tracking-wider mb-2">Platform</div>
								<div class="text-sm">{platforms.length > 0 ? platforms.join(', ') : '—'}</div>
							</div>
						</div>
						{tech.length > 0 && (
							<div class="border-t border-[var(--color-border)] p-5">
								<div class="font-mono text-xs text-[var(--color-muted)] uppercase tracking-wider mb-3">Tech Stack</div>
								<div class="flex flex-wrap gap-2">
									{tech.map((t) => (
										<span class="font-mono text-xs px-2.5 py-1 border border-[var(--color-border)] rounded bg-[var(--color-bg-elev)]">
											{t}
										</span>
									))}
								</div>
							</div>
						)}
					</section>

					<!-- CTA Buttons -->
					{(playableUrl || repoUrl || videoUrl) && (
						<section class="mb-12 flex flex-wrap gap-3 font-mono text-sm">
							{playableUrl && (
								<a
									href={playableUrl}
									target="_blank"
									class="group flex items-center gap-2 border border-[var(--color-accent)] bg-[var(--color-accent-glow)] text-[var(--color-accent)] px-5 py-2.5 rounded hover:bg-[var(--color-accent)] hover:text-[var(--color-bg)] transition"
								>
									<span>▶ play_demo</span>
								</a>
							)}
							{videoUrl && (
								<a
									href={videoUrl}
									target="_blank"
									class="flex items-center gap-2 border border-[var(--color-border-strong)] text-[var(--color-fg)] px-5 py-2.5 rounded hover:border-[var(--color-fg-dim)] transition"
								>
									▶ video
								</a>
							)}
							{repoUrl && (
								<a
									href={repoUrl}
									target="_blank"
									class="flex items-center gap-2 border border-[var(--color-border-strong)] text-[var(--color-fg)] px-5 py-2.5 rounded hover:border-[var(--color-fg-dim)] transition"
								>
									github ↗
								</a>
							)}
						</section>
					)}

					<!-- Case study content -->
					<article class="prose">
						<slot />
					</article>
				</div>
			</div>
		</main>
		<Footer />
		<MermaidScript />
	</body>
</html>
