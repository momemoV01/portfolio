---
// Renders ```mermaid code blocks as diagrams on the client.
// Dynamically imports mermaid only if diagrams exist on the page.
---

<script>
	(async () => {
		const blocks = document.querySelectorAll<HTMLElement>('pre > code.language-mermaid');
		if (blocks.length === 0) return;

		const mermaid = (await import('mermaid')).default;

		// Replace <pre><code> wrappers with <div class="mermaid">
		blocks.forEach((code) => {
			const pre = code.parentElement;
			if (!pre) return;
			const div = document.createElement('div');
			div.className = 'mermaid';
			div.textContent = code.textContent;
			pre.replaceWith(div);
		});

		mermaid.initialize({
			startOnLoad: false,
			securityLevel: 'loose',
			theme: 'base',
			themeVariables: {
				darkMode: true,
				background: '#111113',
				primaryColor: '#1a1a1d',
				primaryTextColor: '#e4e4e7',
				primaryBorderColor: '#a3e635',
				secondaryColor: '#262629',
				tertiaryColor: '#0a0a0a',
				lineColor: '#71717a',
				textColor: '#e4e4e7',
				mainBkg: '#1a1a1d',
				secondBkg: '#262629',
				fontFamily: 'ui-monospace, SFMono-Regular, JetBrains Mono, monospace',
				fontSize: '14px',
			},
		});

		await mermaid.run({ querySelector: '.mermaid' });
	})();
</script>

<style is:global>
	.mermaid {
		display: flex;
		justify-content: center;
		margin: 1.5rem 0;
		padding: 1.25rem;
		background: var(--color-bg-elev);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		overflow-x: auto;
	}
	.mermaid svg {
		max-width: 100%;
		height: auto;
	}
</style>
