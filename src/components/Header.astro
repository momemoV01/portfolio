---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header
	class="border-b border-[var(--color-border)] backdrop-blur-md sticky top-0 z-50"
	style="background: rgba(10, 10, 10, 0.8);"
>
	<nav class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
		<a href="/" class="font-mono text-sm text-[var(--color-fg)] hover:opacity-70 transition">
			<span class="text-[var(--color-accent)]">$</span> {SITE_TITLE.toLowerCase().replace(/\s+/g, '-')}
			<span class="text-[var(--color-accent)]">_</span>
		</a>
		<div class="flex items-center gap-1 font-mono text-sm">
			<HeaderLink href="/projects">projects</HeaderLink>
			<HeaderLink href="/blog">blog</HeaderLink>
			<HeaderLink href="/about">about</HeaderLink>
		</div>
	</nav>
</header>
