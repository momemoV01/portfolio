---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header
	class="border-b border-[var(--color-border)] backdrop-blur-md sticky top-0 z-50"
	style="background: rgba(10, 10, 10, 0.8);"
>
	<nav class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
		<a href="/" class="font-mono text-sm text-[var(--color-fg)] hover:opacity-70 transition">
			<span class="text-[var(--color-accent)]">$</span> {SITE_TITLE.toLowerCase().replace(/\s+/g, '-')}
			<span class="text-[var(--color-accent)]">_</span>
		</a>
		<div class="flex items-center gap-1 font-mono text-sm">
			<HeaderLink href="/projects">projects</HeaderLink>
			<HeaderLink href="/blog">blog</HeaderLink>
			<HeaderLink href="/about">about</HeaderLink>
			<button
				id="width-toggle"
				type="button"
				aria-label="toggle width mode"
				title="Toggle wide / narrow layout"
				class="ml-2 px-2 py-1.5 rounded border border-[var(--color-border)] text-[var(--color-fg-dim)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition text-xs"
			>
				<span class="when-narrow">⟷ wide</span>
				<span class="when-wide">][ narrow</span>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	document.getElementById('width-toggle')?.addEventListener('click', () => {
		const html = document.documentElement;
		const isWide = html.getAttribute('data-width') === 'wide';
		try {
			if (isWide) {
				html.removeAttribute('data-width');
				localStorage.removeItem('width-mode');
			} else {
				html.setAttribute('data-width', 'wide');
				localStorage.setItem('width-mode', 'wide');
			}
		} catch (e) {}
	});
</script>
