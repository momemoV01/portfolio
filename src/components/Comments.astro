// Giscus comments — GitHub Discussions based
// Requires the Giscus GitHub App installed on the repo:
// https://github.com/apps/giscus
---

<section class="mt-16 pt-10 border-t border-[var(--color-border)]">
	<div class="mono-tag mb-6"># comments</div>
	<script
		src="https://giscus.app/client.js"
		data-repo="momemoV01/portfolio"
		data-repo-id="R_kgDOSLsZsg"
		data-category="Announcements"
		data-category-id="DIC_kwDOSLsZss4C7n9d"
		data-mapping="pathname"
		data-strict="0"
		data-reactions-enabled="1"
		data-emit-metadata="0"
		data-input-position="top"
		data-theme="dark_dimmed"
		data-lang="ko"
		data-loading="lazy"
		crossorigin="anonymous"
		async></script>
</section>
