---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR_FULL_NAME, AUTHOR_NAME, AUTHOR_SOCIAL, SITE_TITLE } from '../consts';

// 편집 가능한 섹션 데이터 — 본인 입맛에 맞게 수정
const stack = [
	{ label: 'Engine', items: ['Unity 6', 'Unreal 5'] },
	{ label: 'Language', items: ['C#', 'HLSL', 'TypeScript'] },
	{ label: 'Rendering', items: ['URP', 'Shader Graph', 'Niagara'] },
	{ label: 'Tools', items: ['DOTween', 'UniTask', 'Addressables', 'Git'] },
];

const focus = [
	{ title: 'Real-time rendering', desc: '셰이더, 후처리, 라이팅' },
	{ title: 'Game feel', desc: '피드백, 애니메이션, 사운드의 결' },
	{ title: 'Procedural generation', desc: '코드로 만들어지는 형태와 패턴' },
	{ title: 'Workflow automation', desc: '본인이 쓰는 작은 도구 만들기' },
];

const elsewhere = [
	{
		label: 'email',
		value: AUTHOR_SOCIAL.email,
		href: `mailto:${AUTHOR_SOCIAL.email}`,
		icon: '✉',
	},
	{
		label: 'github',
		value: AUTHOR_SOCIAL.github.replace('https://', ''),
		href: AUTHOR_SOCIAL.github,
		icon: '⌥',
	},
];
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`about · ${SITE_TITLE}`} description="About me" />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-4xl px-6 py-20">
			<!-- HERO -->
			<section class="mb-24">
				<div class="mono-tag terminal-prompt mb-6">whoami</div>
				<h1 class="text-5xl md:text-7xl lg:text-8xl font-bold leading-[0.95] mb-8 tracking-tight">
					{AUTHOR_FULL_NAME}<span class="text-[var(--color-accent)]">.</span>
				</h1>
				<p class="text-xl md:text-2xl text-[var(--color-fg-dim)] leading-relaxed max-w-2xl">
					온라인에선 <span class="text-[var(--color-accent)] font-mono">@{AUTHOR_NAME}</span>.<br
					/>
					Unity로 게임 만들고, Unreal로 비주얼 실험하는 솔로 개발자.
				</p>
				<div class="mt-8 inline-flex items-center gap-2.5 font-mono text-sm text-[var(--color-fg-dim)]">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--color-accent)] opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-accent)]"></span>
					</span>
					<span>currently building things</span>
				</div>
			</section>

			<!-- NOW -->
			<section class="mb-24">
				<div class="grid grid-cols-1 md:grid-cols-[180px_minmax(0,1fr)] gap-6 md:gap-12">
					<div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)] md:pt-2">
						<span class="text-[var(--color-accent)]">▸</span> now
					</div>
					<div>
						<p class="text-xl text-[var(--color-fg)] leading-relaxed mb-4">
							Unity URP 기반 게임 프로토타이핑 중. Shader Graph로 비주얼 실험 반복하면서,
							진행 상황은 <a
								href="/projects"
								class="text-[var(--color-accent)] underline underline-offset-4 decoration-1 hover:decoration-2 transition"
								>projects</a
							>에 매일 기록.
						</p>
						<p class="text-base text-[var(--color-fg-dim)] leading-relaxed">
							동시에 셰이더 학습 노트 정리도 천천히. 결과물보단 과정을 더 자주 남기는 편.
						</p>
					</div>
				</div>
			</section>

			<!-- STACK -->
			<section class="mb-24">
				<div class="grid grid-cols-1 md:grid-cols-[180px_minmax(0,1fr)] gap-6 md:gap-12">
					<div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)] md:pt-2">
						<span class="text-[var(--color-accent)]">▸</span> stack
					</div>
					<div class="space-y-6">
						{stack.map((group) => (
							<div class="grid grid-cols-[100px_minmax(0,1fr)] gap-4 items-start">
								<div class="font-mono text-xs text-[var(--color-muted)] uppercase tracking-wider pt-1.5">
									{group.label}
								</div>
								<div class="flex flex-wrap gap-1.5">
									{group.items.map((item) => (
										<span class="font-mono text-xs px-2.5 py-1 border border-[var(--color-border)] rounded bg-[var(--color-bg-elev)] hover:border-[var(--color-accent)] transition cursor-default">
											{item}
										</span>
									))}
								</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- FOCUS -->
			<section class="mb-24">
				<div class="grid grid-cols-1 md:grid-cols-[180px_minmax(0,1fr)] gap-6 md:gap-12">
					<div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)] md:pt-2">
						<span class="text-[var(--color-accent)]">▸</span> focus
					</div>
					<ul class="space-y-5">
						{focus.map((f) => (
							<li class="group">
								<div class="flex items-baseline gap-3">
									<span class="font-mono text-[10px] text-[var(--color-accent)] tabular-nums w-6">
										{String(focus.indexOf(f) + 1).padStart(2, '0')}
									</span>
									<div>
										<h3 class="text-lg font-semibold mb-0.5 group-hover:text-[var(--color-accent)] transition">
											{f.title}
										</h3>
										<p class="text-sm text-[var(--color-fg-dim)]">{f.desc}</p>
									</div>
								</div>
							</li>
						))}
					</ul>
				</div>
			</section>

			<!-- HERE -->
			<section class="mb-24">
				<div class="grid grid-cols-1 md:grid-cols-[180px_minmax(0,1fr)] gap-6 md:gap-12">
					<div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)] md:pt-2">
						<span class="text-[var(--color-accent)]">▸</span> here
					</div>
					<div class="space-y-3 text-base">
						<p>
							<a
								href="/projects"
								class="font-mono text-sm text-[var(--color-fg)] hover:text-[var(--color-accent)] transition"
								>./projects</a
							>
							<span class="text-[var(--color-fg-dim)] ml-2">— 게임/프로토타입 + 진행 일지</span>
						</p>
						<p>
							<a
								href="/blog"
								class="font-mono text-sm text-[var(--color-fg)] hover:text-[var(--color-accent)] transition"
								>./blog</a
							>
							<span class="text-[var(--color-fg-dim)] ml-2">— 기술 노트 · 일상 짧은 글</span>
						</p>
					</div>
				</div>
			</section>

			<!-- ELSEWHERE -->
			<section>
				<div class="grid grid-cols-1 md:grid-cols-[180px_minmax(0,1fr)] gap-6 md:gap-12">
					<div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)] md:pt-2">
						<span class="text-[var(--color-accent)]">▸</span> elsewhere
					</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
						{elsewhere.map((link) => (
							<a
								href={link.href}
								target={link.href.startsWith('http') ? '_blank' : undefined}
								rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
								class="group flex items-center gap-4 px-5 py-4 border border-[var(--color-border)] rounded-lg hover:border-[var(--color-accent)] hover:bg-[var(--color-bg-elev)] transition"
							>
								<span class="text-xl text-[var(--color-fg-dim)] group-hover:text-[var(--color-accent)] transition">
									{link.icon}
								</span>
								<div class="min-w-0 flex-1">
									<div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)]">
										{link.label}
									</div>
									<div class="text-sm text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition truncate">
										{link.value}
									</div>
								</div>
								<span class="font-mono text-xs text-[var(--color-muted)] group-hover:text-[var(--color-accent)] transition">
									→
								</span>
							</a>
						))}
					</div>
				</div>
			</section>

			<!-- Footer line -->
			<div class="mt-24 pt-8 border-t border-[var(--color-border)] font-mono text-xs text-[var(--color-muted)] flex flex-wrap items-center justify-between gap-3">
				<span>last updated · {new Date().toISOString().split('T')[0]}</span>
				<span class="text-[var(--color-accent)]">_</span>
			</div>
		</main>
		<Footer />
	</body>
</html>
