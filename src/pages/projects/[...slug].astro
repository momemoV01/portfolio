---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Project from '../../layouts/Project.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects', ({ data }) => !data.draft);
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}
type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await render(project);

// Gather devlogs that reference this project
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const devlogs = allPosts
	.filter((p) => p.data.project?.id === project.id)
	.sort((a, b) => {
		const dayA = a.data.day ?? 0;
		const dayB = b.data.day ?? 0;
		if (dayA !== dayB) return dayA - dayB;
		return a.data.pubDate.valueOf() - b.data.pubDate.valueOf();
	});
---

<Project {...project.data} projectId={project.id} devlogs={devlogs}>
	<Content />
</Project>
