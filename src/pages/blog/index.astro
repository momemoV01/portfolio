---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogExplorer, { type PostItem } from '../../components/BlogExplorer';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postsData: PostItem[] = posts.map((p) => ({
	id: p.id,
	title: p.data.title,
	description: p.data.description,
	category: p.data.category,
	tags: p.data.tags,
	pubDate: p.data.pubDate.toISOString(),
}));
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`blog · ${SITE_TITLE}`} description="Notes, devlogs, and daily" />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-5xl px-6 py-16">
			<header class="mb-12">
				<div class="mono-tag terminal-prompt mb-3">cat ./blog/index.md</div>
				<h1 class="mb-3">Blog</h1>
				<p class="text-lg text-[var(--color-fg-dim)]">개발 과정, 기술 노트, 그리고 일상</p>
			</header>

			<BlogExplorer posts={postsData} client:load />
		</main>
		<Footer />
	</body>
</html>
